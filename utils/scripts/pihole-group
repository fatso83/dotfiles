#!/usr/bin/env bash
# 0 8 * * 6,0 pihole-group disable Spill-blokk
# 0 8 * * 6,0 pihole-group disable Youtube-blokk
# 0 13 * * 6,0 pihole-group enable Spill-blokk
# 0 13 * * 6,0 pihole-group enable Youtube-blokk

set -euo pipefail

DB="/etc/pihole/gravity.db"

usage() {
  echo "Usage: $0 list | enable|disable <group-name>" >&2
  exit 2
}

list() {
  sudo sqlite3 "$DB" 'SELECT id,name,enabled FROM "group";'
}

case "${1-}" in
  list)
    [[ $# -eq 1 ]] || usage
    list
    exit 0
    ;;
  enable|disable)
    [[ $# -eq 2 ]] || usage
    action="$1"
    group="$2"
    ;;
  *)
    usage
    ;;
esac

case "$action" in
  enable)  enabled=1 ;;
  disable) enabled=0 ;;
esac

# Escape single quotes for SQLite string literal
sql_group=$(printf "%s" "$group" | sed "s/'/''/g")

count=$(
  sqlite3 "$DB" "SELECT COUNT(*) FROM \"group\" WHERE name = '$sql_group';"
)

if [[ "$count" != "1" ]]; then
  echo "Group not found: $group" >&2
  exit 1
fi

sqlite3 "$DB" "UPDATE \"group\" SET enabled = $enabled WHERE name = '$sql_group';"

SIGRTMIN="$(pihole-FTL sigrtmin)"
pkill "-SIG${SIGRTMIN}" pihole-FTL

echo "Group '$group' ${action}d."
